<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.agentsview.pg-serve</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/mariusvniekerk/.local/share/mise/installs/github-wesm-agentsview/0.25.0/agentsview</string>
